# ## SERVER CONFIG
SERVER_FRONTEND_DOMAIN="http://localhost:5173"
# Integration tests run the proxy locally on 127.0.0.1 with an mkcert dev cert
# for ivpndns.com / *.ivpndns.com. The api emits stamps & mobileconfig pointing
# at these values, so they must match what the proxy actually serves on this
# host network. Production overrides via ansible (see ansible/.../api.env.j2).
SERVER_DNS_DOMAIN="ivpndns.com"
SERVER_DNS_SERVER_ADDRESSES="127.0.0.1"
SERVER_ALLOWED_DOMAINS=app.ivpndns.net,api.ivpndns.net,test.moddns.net

# ## SERVICE CONFIG
OTP_EXPIRATION=5m
MOBILECONFIG_PRIVATE_KEY_PATH="/certs/private_key.pem"
MOBILECONFIG_CERT_PATH="/certs/certificate.pem"

# ## ZLA PRE-AUTH CONFIG
PREAUTH_URL=http://mock-preauth:8080
PREAUTH_PSK=
PREAUTH_TTL=60m

# ## API CONFIG
API_PORT=:3000
API_SESSION_EXPIRATION=8h
API_BASIC_AUTH_USERNAME=
API_BASIC_AUTH_PASSWORD=
API_ALLOW_ORIGIN="http://localhost:5173"
API_RATE_LIMIT=100
API_ALLOW_IP=*
API_DISABLE_RATE_LIMIT=true

# ## DB CONFIG
DB_URI=mongodb://mongodb:27017
DB_NAME=dns
DB_USERNAME=admin
DB_PASSWORD=admin
DB_AUTH_SOURCE=admin
DB_MIGRATIONS_SOURCE=file:///db/mongodb/migrations

# ## CACHE CONFIG
CACHE_ADDRESS=cache:6379
# Sentinel (optional failover) configuration
CACHE_MASTER_NAME=mymaster
CACHE_ADDRESSES=sentinel1:26379,sentinel2:26379,sentinel3:26379
# CACHE_USERNAME="api"
CACHE_PASSWORD=appCacheTestPass123
CACHE_USERNAME=appcache
CACHE_FAILOVER_USERNAME=failovercache
CACHE_FAILOVER_PASSWORD=failoverCacheTestPass456


# ## EMAIL SENDER CONFIG
EMAIL_SENDER_TYPE=mailpit
EMAIL_SENDER_INBOX_ID=
EMAIL_SENDER_AUTH_TOKEN=

# ## SERVICES / ASN BLOCKING (optional)
SERVICES_CATALOG_PATH=/opt/services/catalog.yml
GEOIP_DB_ASN_FILE=/opt/geo/GeoLite2-ASN.mmdb
